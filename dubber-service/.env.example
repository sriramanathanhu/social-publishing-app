# Dubber service config. Copy to .env (gitignored). No user API keys here —
# those arrive per-job in the request body from the PeerPost backend.

# Shared bearer token. PeerPost sends this as `Authorization: Bearer <token>`.
# Generate a long random string; keep it identical on both sides.
DUBBER_SERVICE_TOKEN=change_me_long_random

# Where finished videos are written (spike: local disk).
DUBBER_OUTPUT_DIR=outputs

# Deepgram model override (default nova-2).
DEEPGRAM_MODEL=nova-2

# Port for uvicorn (see README run command). Pick one free on the host —
# 3009/3005-3008/3100/3101 are taken by other apps per PeerPost CLAUDE.md.
DUBBER_PORT=8800

# Optional yt-dlp authentication for login-gated / rate-limited sources
# (Instagram, private posts, age-gated YouTube). Export a Netscape-format
# cookies.txt from a logged-in browser and point this at it (absolute path).
# Without it, anonymous downloads of restricted content fail with "login required".
YTDLP_COOKIES_FILE=
# Alternative: read cookies live from a local browser profile (rarely available
# on a headless server). e.g. "firefox" or "chrome".
YTDLP_COOKIES_FROM_BROWSER=
