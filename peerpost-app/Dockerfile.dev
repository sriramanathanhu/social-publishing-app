# Local-development image for the PeerPost Next.js app.
#
# Dependencies are installed *inside* the container so native binaries (Next/SWC,
# Tailwind oxide, Biome) match Linux. docker-compose bind-mounts the source for
# hot reload and keeps this image's node_modules via a named volume so the host's
# (possibly macOS) node_modules never shadows the Linux ones.
FROM node:22-bookworm-slim

# pnpm via corepack, version pinned by package.json "packageManager".
RUN corepack enable

WORKDIR /app

# Cached dependency layer — only re-runs when the manifests change.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# App source (overlaid by the compose bind-mount during dev).
COPY . .

EXPOSE 3009

# db:push is idempotent (creates tables on a fresh DB); safe on every start.
# Plain `next dev` (no turbopack) so WATCHPACK_POLLING drives reliable HMR over
# the Docker bind mount.
CMD ["sh", "-c", "pnpm db:push && pnpm exec next dev -H 0.0.0.0 -p 3009"]
