{
	"compilerOptions": {
		"module": "esnext",
		"moduleResolution": "bundler",
		"target": "es2022",
		"lib": ["es2022"],
		"types": ["node"],
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"esModuleInterop": true,
		"resolveJsonModule": true
	},
	"include": ["**/*.ts", "../src/db/schema.ts"]
}
