# ── App ───────────────────────────────────────────────
NEXT_BASE_URL=http://localhost:3000

# ── Nandi SSO (from the Nandi auth example) ───────────
NEXT_AUTH_URL=https://your-nandi-auth-server.com
NEXT_AUTH_CLIENT_ID=your_client_id
AUTH_CLIENT_SECRET=your_client_secret

# ── PostPeer (server-side only — NEVER expose to client)
POSTPEER_BASE_URL=https://api.postpeer.dev/v1
POSTPEER_API_KEY=your_postpeer_access_key

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/peerpost

# Daily analytics refresh cron auth (any random string)
CRON_SECRET=your_cron_secret

# MCP server
MCP_PORT=3010
MCP_PUBLIC_URL=https://post-dev.kailasa.ai

# Optional: Google Drive service-account JSON (read-only) to expand Drive
# FOLDER links and read private files via the MCP. Share folders with the SA email.
GOOGLE_DRIVE_SA_JSON=

# ── Dubber service (../dubber-service sidecar) ────────
# Internal HTTP URL of the Python dubbing service and the shared bearer token
# (must match DUBBER_SERVICE_TOKEN in dubber-service/.env).
DUBBER_SERVICE_URL=http://127.0.0.1:8800
DUBBER_SERVICE_TOKEN=change_me_long_random

# Secret used to encrypt per-user dub API keys at rest (AES-256-GCM, ≥16 chars).
# Rotating this invalidates stored keys — users must re-enter them.
KEY_ENCRYPTION_SECRET=change_me_long_random_secret
